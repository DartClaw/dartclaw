# Scenario run artifacts (results/<scenario>-<timestamp>/) — never committed.
scenarios/results/

# The generic workflow fixture should use runtime-materialized built-ins
# rather than checked-in copies.
**/workspace/workflows/

# The visual profile is a committed fixture, not just a scratch runtime.
# Re-include its seeded corpus so scenario-critical pages render meaningful data.
!profiles/visual/data/kv.json
!profiles/visual/data/search.db
!profiles/visual/data/state.db
!profiles/visual/data/tasks.db
!profiles/visual/data/usage.jsonl
!profiles/visual/data/sessions/
!profiles/visual/data/sessions/**
!profiles/visual/data/tasks/
!profiles/visual/data/tasks/**
!profiles/visual/data/workspace/errors.md
!profiles/visual/data/workspace/learnings.md
!profiles/visual/data/workspace/memory/
!profiles/visual/data/workspace/memory/**
